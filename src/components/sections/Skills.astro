---
// Skills.astro — Updated with real LinkedIn skills data
---

<section id="skills" class="section-pad wrap">
  <div class="section-head reveal">
    <div>
      <span class="eyebrow">Tech Stack</span>
      <h2 class="section-title" style="margin-top:18px">Tools of the trade</h2>
    </div>
    <span class="section-index" aria-hidden="true">/ 02 — 06</span>
  </div>

  <div class="stack-rows">
    <div class="stack-row reveal">
      <div class="stack-cat">
        <span class="stack-num" aria-hidden="true">01</span>
        Backend
      </div>
      <div class="stack-techs" role="list" aria-label="Backend technologies">
        <span role="listitem">Laravel</span>
        <span role="listitem">PHP</span>
        <span role="listitem">Node.js</span>
        <span role="listitem">CodeIgniter</span>
        <span role="listitem">REST API</span>
        <span role="listitem">MySQL</span>
        <span role="listitem">PostgreSQL</span>
      </div>
    </div>

    <div class="stack-row reveal">
      <div class="stack-cat">
        <span class="stack-num" aria-hidden="true">02</span>
        Frontend
      </div>
      <div class="stack-techs" role="list" aria-label="Frontend technologies">
        <span role="listitem">Vue.js</span>
        <span role="listitem">JavaScript</span>
        <span role="listitem">HTML &amp; CSS</span>
        <span role="listitem">Bootstrap</span>
        <span role="listitem">jQuery</span>
        <span role="listitem">Tailwind</span>
      </div>
    </div>

    <div class="stack-row reveal">
      <div class="stack-cat">
        <span class="stack-num" aria-hidden="true">03</span>
        AI &amp; Data
      </div>
      <div class="stack-techs" role="list" aria-label="AI and Data technologies">
        <span role="listitem">Generative AI</span>
        <span role="listitem">Prompt Engineering</span>
        <span role="listitem">Microsoft Azure AI</span>
        <span role="listitem">IBM SkillsBuild</span>
        <span role="listitem">Python</span>
        <span role="listitem">Data Science</span>
      </div>
    </div>

    <div class="stack-row reveal">
      <div class="stack-cat">
        <span class="stack-num" aria-hidden="true">04</span>
        Platform &amp; Tools
      </div>
      <div class="stack-techs" role="list" aria-label="Platform and DevOps technologies">
        <span role="listitem">Odoo ERP</span>
        <span role="listitem">Linux</span>
        <span role="listitem">Git</span>
        <span role="listitem">Docker</span>
        <span role="listitem">VPS / cPanel</span>
        <span role="listitem">AWS Skill Builder</span>
      </div>
    </div>
  </div>
</section>
