---
// Skills.astro
---

<section id="skills" class="section-pad wrap">
  <div class="section-head reveal">
    <div>
      <span class="eyebrow">Tech Stack</span>
      <h2 class="section-title" style="margin-top:18px">Tools of the trade</h2>
    </div>
    <span class="section-index" aria-hidden="true">/ 02 — 06</span>
  </div>

  <div class="stack-rows">
    <div class="stack-row reveal">
      <div class="stack-cat">
        <span class="stack-num" aria-hidden="true">01</span>
        Frontend
      </div>
      <div class="stack-techs" role="list" aria-label="Frontend technologies">
        <span role="listitem">React</span>
        <span role="listitem">Next.js</span>
        <span role="listitem">TypeScript</span>
        <span role="listitem">Tailwind</span>
        <span role="listitem">Framer Motion</span>
        <span role="listitem">Vite</span>
      </div>
    </div>

    <div class="stack-row reveal">
      <div class="stack-cat">
        <span class="stack-num" aria-hidden="true">02</span>
        Backend
      </div>
      <div class="stack-techs" role="list" aria-label="Backend technologies">
        <span role="listitem">Node.js</span>
        <span role="listitem">Python</span>
        <span role="listitem">FastAPI</span>
        <span role="listitem">Express</span>
        <span role="listitem">PostgreSQL</span>
        <span role="listitem">Redis</span>
        <span role="listitem">GraphQL</span>
      </div>
    </div>

    <div class="stack-row reveal">
      <div class="stack-cat">
        <span class="stack-num" aria-hidden="true">03</span>
        AI / ML
      </div>
      <div class="stack-techs" role="list" aria-label="AI and ML technologies">
        <span role="listitem">PyTorch</span>
        <span role="listitem">LangChain</span>
        <span role="listitem">LlamaIndex</span>
        <span role="listitem">OpenAI</span>
        <span role="listitem">Hugging Face</span>
        <span role="listitem">RAG</span>
        <span role="listitem">Vector DBs</span>
      </div>
    </div>

    <div class="stack-row reveal">
      <div class="stack-cat">
        <span class="stack-num" aria-hidden="true">04</span>
        Infra / DevOps
      </div>
      <div class="stack-techs" role="list" aria-label="Infrastructure and DevOps technologies">
        <span role="listitem">Docker</span>
        <span role="listitem">Kubernetes</span>
        <span role="listitem">AWS</span>
        <span role="listitem">CI/CD</span>
        <span role="listitem">Terraform</span>
        <span role="listitem">Vercel</span>
      </div>
    </div>
  </div>
</section>
