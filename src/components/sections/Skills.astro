---
// Skills.astro — 3-tier skill pills + YOE badges, inspired by faisalaffan.com
---

<section id="stack" class="section-pad wrap">
  <div class="section-head reveal">
    <div>
      <span class="eyebrow">Tech Stack</span>
      <h2 class="section-title" style="margin-top:18px">Tools of the trade</h2>
    </div>
    <span class="section-index" aria-hidden="true">/ 02 — 07</span>
  </div>

  <div class="skills-desc reveal" data-d="2">
    <p>Keahlian yang saya gunakan sehari-hari — dari backend yang kuat, frontend yang responsif, hingga sistem AI yang mulai saya integrasikan ke produk nyata.</p>
    <div class="skills-legend">
      <span class="legend-item core">● Core — teknologi utama</span>
      <span class="legend-item strong">● Strong — sangat mahir</span>
      <span class="legend-item working">○ Growing — sedang berkembang</span>
    </div>
  </div>

  <!-- Backend -->
  <div class="skill-category reveal" data-d="2">
    <div class="skill-cat-header">
      <div class="skill-cat-badge backend">
        <span>⚙</span>
        <span>Backend</span>
        <span class="cat-yoe-badge">10+ yrs</span>
      </div>
    </div>
    <div class="skill-pills-row">
      <div class="skill-pill-core">
        <span class="skill-name">Laravel</span>
        <span class="yoe-badge yoe-badge-core">8y</span>
      </div>
      <div class="skill-pill-core">
        <span class="skill-name">PHP</span>
        <span class="yoe-badge yoe-badge-core">10y</span>
      </div>
      <div class="skill-pill-core">
        <span class="skill-name">Node.js</span>
        <span class="yoe-badge yoe-badge-core">5y</span>
      </div>
      <div class="skill-pill-core">
        <span class="skill-name">REST API</span>
        <span class="yoe-badge yoe-badge-core">8y</span>
      </div>
      <div class="skill-pill-core">
        <span class="skill-name">MySQL</span>
        <span class="yoe-badge yoe-badge-core">10y</span>
      </div>
      <div class="skill-pill-strong">
        <span class="skill-name">PostgreSQL</span>
        <span class="yoe-badge yoe-badge-strong">4y</span>
      </div>
      <div class="skill-pill-strong">
        <span class="skill-name">CodeIgniter</span>
        <span class="yoe-badge yoe-badge-strong">6y</span>
      </div>
      <div class="skill-pill-working">
        <span class="skill-name">GraphQL</span>
        <span class="yoe-badge yoe-badge-working">1y</span>
      </div>
    </div>
    <div class="skill-percent-bar" data-pct="92">
      <div class="skill-percent-label"><span>Backend proficiency</span><span class="pct-val">92%</span></div>
      <div class="skill-percent-track"><div class="percent-bar-fill" style="width:92%;background:var(--color-brand-accent)"></div></div>
    </div>
  </div>

  <!-- Frontend -->
  <div class="skill-category reveal" data-d="3">
    <div class="skill-cat-header">
      <div class="skill-cat-badge frontend">
        <span>✦</span>
        <span>Frontend</span>
        <span class="cat-yoe-badge">8+ yrs</span>
      </div>
    </div>
    <div class="skill-pills-row">
      <div class="skill-pill-core">
        <span class="skill-name">Vue.js</span>
        <span class="yoe-badge yoe-badge-core">6y</span>
      </div>
      <div class="skill-pill-core">
        <span class="skill-name">JavaScript</span>
        <span class="yoe-badge yoe-badge-core">10y</span>
      </div>
      <div class="skill-pill-core">
        <span class="skill-name">HTML &amp; CSS</span>
        <span class="yoe-badge yoe-badge-core">10y</span>
      </div>
      <div class="skill-pill-strong">
        <span class="skill-name">React.js</span>
        <span class="yoe-badge yoe-badge-strong">2y</span>
      </div>
      <div class="skill-pill-strong">
        <span class="skill-name">TypeScript</span>
        <span class="yoe-badge yoe-badge-strong">2y</span>
      </div>
      <div class="skill-pill-strong">
        <span class="skill-name">Tailwind</span>
        <span class="yoe-badge yoe-badge-strong">3y</span>
      </div>
      <div class="skill-pill-strong">
        <span class="skill-name">Bootstrap</span>
        <span class="yoe-badge yoe-badge-strong">7y</span>
      </div>
      <div class="skill-pill-working">
        <span class="skill-name">Next.js</span>
        <span class="yoe-badge yoe-badge-working">1y</span>
      </div>
    </div>
    <div class="skill-percent-bar">
      <div class="skill-percent-label"><span>Frontend proficiency</span><span class="pct-val">82%</span></div>
      <div class="skill-percent-track"><div class="percent-bar-fill" style="width:82%;background:color-mix(in srgb,var(--color-brand-accent) 80%,#a78bfa)"></div></div>
    </div>
  </div>

  <!-- AI & Data -->
  <div class="skill-category reveal" data-d="4">
    <div class="skill-cat-header">
      <div class="skill-cat-badge ai">
        <span>◈</span>
        <span>AI &amp; Data</span>
        <span class="cat-yoe-badge">2+ yrs</span>
      </div>
    </div>
    <div class="skill-pills-row">
      <div class="skill-pill-core">
        <span class="skill-name">Generative AI</span>
        <span class="yoe-badge yoe-badge-core">2y</span>
      </div>
      <div class="skill-pill-core">
        <span class="skill-name">Prompt Engineering</span>
        <span class="yoe-badge yoe-badge-core">2y</span>
      </div>
      <div class="skill-pill-strong">
        <span class="skill-name">Python</span>
        <span class="yoe-badge yoe-badge-strong">2y</span>
      </div>
      <div class="skill-pill-strong">
        <span class="skill-name">RAG Pipeline</span>
        <span class="yoe-badge yoe-badge-strong">1y</span>
      </div>
      <div class="skill-pill-working">
        <span class="skill-name">Microsoft Azure AI</span>
        <span class="yoe-badge yoe-badge-working">1y</span>
      </div>
      <div class="skill-pill-working">
        <span class="skill-name">Data Science</span>
        <span class="yoe-badge yoe-badge-working">1y</span>
      </div>
    </div>
    <div class="skill-percent-bar">
      <div class="skill-percent-label"><span>AI proficiency</span><span class="pct-val">68%</span></div>
      <div class="skill-percent-track"><div class="percent-bar-fill" style="width:68%;background:color-mix(in srgb,var(--color-brand-accent) 60%,#6366f1)"></div></div>
    </div>
  </div>

  <!-- Platform & Tools -->
  <div class="skill-category reveal" data-d="2">
    <div class="skill-cat-header">
      <div class="skill-cat-badge platform">
        <span>⊞</span>
        <span>Platform &amp; DevOps</span>
        <span class="cat-yoe-badge">8+ yrs</span>
      </div>
    </div>
    <div class="skill-pills-row">
      <div class="skill-pill-core">
        <span class="skill-name">Odoo ERP</span>
        <span class="yoe-badge yoe-badge-core">5y</span>
      </div>
      <div class="skill-pill-core">
        <span class="skill-name">Linux</span>
        <span class="yoe-badge yoe-badge-core">8y</span>
      </div>
      <div class="skill-pill-core">
        <span class="skill-name">Git</span>
        <span class="yoe-badge yoe-badge-core">10y</span>
      </div>
      <div class="skill-pill-strong">
        <span class="skill-name">Docker</span>
        <span class="yoe-badge yoe-badge-strong">3y</span>
      </div>
      <div class="skill-pill-strong">
        <span class="skill-name">VPS / cPanel</span>
        <span class="yoe-badge yoe-badge-strong">6y</span>
      </div>
      <div class="skill-pill-working">
        <span class="skill-name">AWS</span>
        <span class="yoe-badge yoe-badge-working">1y</span>
      </div>
      <div class="skill-pill-working">
        <span class="skill-name">CI/CD</span>
        <span class="yoe-badge yoe-badge-working">1y</span>
      </div>
    </div>
    <div class="skill-percent-bar">
      <div class="skill-percent-label"><span>Platform proficiency</span><span class="pct-val">78%</span></div>
      <div class="skill-percent-track"><div class="percent-bar-fill" style="width:78%;background:color-mix(in srgb,var(--color-brand-accent) 70%,#a78bfa)"></div></div>
    </div>
  </div>
</section>

<script>
  // Animate percent bars when they scroll into view
  const bars = document.querySelectorAll('.percent-bar-fill');
  const barObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.animation = 'percentFill 0.8s cubic-bezier(0.25, 1, 0.5, 1) forwards';
        barObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  bars.forEach(b => barObs.observe(b));
</script>

<style>
  .skills-desc {
    margin: 24px 0 40px;
    max-width: 600px;
  }
  .skills-desc p {
    font-size: 0.95rem;
    color: var(--color-brand-text-secondary);
    line-height: 1.7;
    margin: 0 0 16px;
  }
  .skills-legend {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .legend-item {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-brand-text-tertiary);
  }
  .legend-item.core { color: var(--color-brand-accent); }
  .legend-item.strong { color: var(--color-brand-text-secondary); }

  /* Category */
  .skill-category {
    margin-bottom: 48px;
    border-bottom: 1px solid var(--color-brand-border);
    padding-bottom: 40px;
  }
  .skill-category:last-of-type { border-bottom: none; }
  .skill-cat-header { margin-bottom: 20px; }

  .skill-cat-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid;
    letter-spacing: 0.02em;
    transition: box-shadow 0.2s;
    cursor: default;
  }
  .skill-cat-badge:hover {
    box-shadow: 0 0 12px color-mix(in srgb, currentColor 25%, transparent);
  }
  .skill-cat-badge.backend { color: #7c6cfc; background: color-mix(in srgb, #7c6cfc 10%, transparent); border-color: color-mix(in srgb, #7c6cfc 25%, transparent); }
  .skill-cat-badge.frontend { color: #a78bfa; background: color-mix(in srgb, #a78bfa 10%, transparent); border-color: color-mix(in srgb, #a78bfa 25%, transparent); }
  .skill-cat-badge.ai { color: #6366f1; background: color-mix(in srgb, #6366f1 10%, transparent); border-color: color-mix(in srgb, #6366f1 25%, transparent); }
  .skill-cat-badge.platform { color: #8b5cf6; background: color-mix(in srgb, #8b5cf6 10%, transparent); border-color: color-mix(in srgb, #8b5cf6 25%, transparent); }

  .cat-yoe-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    padding: 0.08rem 0.35rem;
    border-radius: 999px;
    background: color-mix(in srgb, currentColor 15%, transparent);
    color: inherit;
    white-space: nowrap;
  }

  /* Pill rows */
  .skill-pills-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 20px;
  }

  /* Core pill */
  .skill-pill-core {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: var(--color-brand-accent-soft);
    border: 1.5px solid var(--color-brand-accent);
    border-radius: 8px;
    transition: transform 0.2s ease;
    cursor: pointer;
  }
  .skill-pill-core:hover { transform: translateY(-2px); }

  /* Strong pill */
  .skill-pill-strong {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    background: var(--color-brand-surface);
    border: 1px solid var(--color-brand-border);
    border-radius: 8px;
    transition: transform 0.2s ease, border-color 0.2s ease;
    cursor: pointer;
  }
  .skill-pill-strong:hover { transform: translateY(-2px); border-color: var(--color-brand-text-secondary); }

  /* Working/growing pill */
  .skill-pill-working {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: var(--color-brand-surface-alt);
    border: 1px dashed var(--color-brand-border);
    border-radius: 8px;
    transition: transform 0.2s ease, border-color 0.2s ease;
    cursor: pointer;
  }
  .skill-pill-working:hover {
    transform: translateY(-2px);
    border-color: var(--color-brand-text-tertiary);
    border-style: solid;
  }

  .skill-name {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-brand-text-primary);
  }
  .skill-pill-working .skill-name { color: var(--color-brand-text-secondary); }

  /* YOE badges */
  .yoe-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .yoe-badge-core { background: var(--color-brand-accent); color: #fff; }
  .yoe-badge-strong {
    background: color-mix(in srgb, var(--color-brand-accent) 15%, transparent);
    color: var(--color-brand-accent);
  }
  .yoe-badge-working {
    background: var(--color-brand-border);
    color: var(--color-brand-text-tertiary);
  }

  /* Percent bar */
  .skill-percent-bar { margin-top: 8px; }
  .skill-percent-label {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-brand-text-tertiary);
    margin-bottom: 6px;
  }
  .pct-val { color: var(--color-brand-accent); font-weight: 700; }
  .skill-percent-track {
    height: 3px;
    background: var(--color-brand-border);
    border-radius: 99px;
    overflow: hidden;
  }
  .percent-bar-fill {
    height: 100%;
    border-radius: 99px;
    transform-origin: left;
    transform: scaleX(0);
  }
  @keyframes percentFill {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }
</style>
