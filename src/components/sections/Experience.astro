---
// Experience.astro — Updated with real LinkedIn experience data
import TimelineItem from '../TimelineItem.astro';

const experiences = [
  {
    period: 'Apr 2022 — Sekarang',
    role: 'IT Manager',
    company: 'PT Mitra Inovasi Gemilang',
    location: 'Jakarta, Indonesia · On-site',
    desc: 'Memimpin tim IT dan mengelola infrastruktur teknologi perusahaan. Merancang dan mengimplementasikan sistem informasi, mengelola server Linux, serta memastikan keandalan dan keamanan sistem. Bertanggung jawab atas pengembangan aplikasi internal berbasis Laravel dan Vue.js.',
    chips: ['Laravel', 'Vue.js', 'Linux', 'MySQL', 'IT Management'],
  },
  {
    period: 'Jan 2022 — Sekarang',
    role: 'Freelance Full Stack Developer',
    company: 'Self-employed',
    location: 'Remote',
    desc: 'Menerima dan mengerjakan proyek dari berbagai klien — mulai dari sistem informasi sekolah, aplikasi kasir, website company profile, hingga integrasi API. Menggunakan Laravel, Vue.js, Node.js, dan MySQL sebagai stack utama.',
    chips: ['Laravel', 'Vue.js', 'Node.js', 'REST API'],
  },
  {
    period: 'Jun 2019 — Mar 2022',
    role: 'Full Stack Developer',
    company: 'PT. Nurul Fikri Cipta Inovasi',
    location: 'Jakarta, Indonesia',
    desc: 'Mengembangkan dan memelihara aplikasi web berbasis Laravel untuk kebutuhan bisnis dan pendidikan. Mengimplementasikan fitur-fitur baru, melakukan code review, dan bekerja sama dengan tim dalam metodologi Agile.',
    chips: ['Laravel', 'PHP', 'MySQL', 'JavaScript', 'Agile'],
  },
  {
    period: '2013 — 2019',
    role: 'Web Developer',
    company: 'Berbagai Perusahaan',
    location: 'Jakarta & Sekitarnya',
    desc: 'Mengawali karir sebagai web developer dengan menguasai PHP, MySQL, HTML/CSS, dan JavaScript. Mengerjakan berbagai proyek website dan sistem informasi untuk klien dari sektor pendidikan, kesehatan, dan bisnis.',
    chips: ['PHP', 'MySQL', 'HTML', 'CSS', 'JavaScript'],
  },
];
---

<section id="experience" class="section-pad wrap">
  <div class="section-head reveal">
    <div>
      <span class="eyebrow">Journey</span>
      <h2 class="section-title" style="margin-top:18px">The road so far</h2>
    </div>
    <span class="section-index" aria-hidden="true">/ 05 — 06</span>
  </div>

  <div class="timeline" aria-label="Work experience timeline">
    <div class="tl-line" aria-hidden="true">
      <div class="fill" id="tl-fill"></div>
    </div>
    {experiences.map(exp => (
      <TimelineItem {...exp} />
    ))}
  </div>
</section>
