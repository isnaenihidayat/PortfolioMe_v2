---
// Work.astro
import WorkCard from '../WorkCard.astro';

const projects = [
  {
    num: '01',
    year: '2025',
    tag: 'RAG · SUPPORT',
    title: 'NeuraDesk',
    desc: 'Platform support berbasis RAG yang menjawab pertanyaan pelanggan dari knowledge base internal — dengan sitasi sumber dan handoff ke manusia.',
    stack: ['Next.js', 'FastAPI', 'LangChain', 'pgvector'],
    image: '/images/neuradesk.png',
    imageAlt: 'NeuraDesk — RAG-based customer support platform showing AI chat with source citations',
    delay: undefined,
  },
  {
    num: '02',
    year: '2025',
    tag: 'ANALYTICS',
    title: 'FluxBoard',
    desc: 'Dashboard analitik realtime full-stack dengan streaming data, kolaborasi multi-user, dan ringkasan otomatis bertenaga LLM.',
    stack: ['React', 'Node.js', 'WebSocket', 'Redis'],
    image: '/images/fluxboard.png',
    imageAlt: 'FluxBoard — Real-time analytics dashboard with streaming data visualizations',
    delay: '2',
  },
  {
    num: '03',
    year: '2024',
    tag: 'AI AGENT',
    title: 'CodeWeaver',
    desc: 'Asisten coding agentic yang membaca repo, merencanakan perubahan multi-file, dan membuka pull request — dibungkus extension & web UI.',
    stack: ['TypeScript', 'Python', 'Agents', 'Docker'],
    image: '/images/codeweaver.png',
    imageAlt: 'CodeWeaver — AI coding assistant with multi-file planning and agent reasoning panel',
    delay: undefined,
  },
  {
    num: '04',
    year: '2024',
    tag: 'COMPUTER VISION',
    title: 'VisionLedger',
    desc: 'Pipeline computer-vision untuk ekstraksi dokumen keuangan — OCR, klasifikasi, dan rekonsiliasi otomatis ke dalam ERP.',
    stack: ['PyTorch', 'FastAPI', 'AWS', 'Postgres'],
    image: '/images/visionledger.png',
    imageAlt: 'VisionLedger — Computer vision document processing pipeline with OCR and ERP sync',
    delay: '2',
  },
];
---

<section id="work" class="section-pad wrap">
  <div class="section-head reveal">
    <div>
      <span class="eyebrow">Selected Work</span>
      <h2 class="section-title" style="margin-top:18px">Things I've built</h2>
    </div>
    <span class="section-index" aria-hidden="true">/ 03 — 06</span>
  </div>

  <div class="work-grid">
    {projects.map(project => (
      <WorkCard {...project} />
    ))}
  </div>
</section>
