---
// Hero.astro
---

<header id="top" class="hero wrap">

  <div class="hero-status reveal">
    <span class="dot-live" aria-hidden="true"></span>
    Available for select projects · 2026
  </div>

  <h1 class="hero-title">
    <span class="line"><span>Building</span></span>
    <span class="line"><span class="accent">intelligent</span></span>
    <span class="line"><span class="outline">products</span> <span>end</span></span>
    <span class="line"><span>to end.</span></span>
  </h1>

  <p class="hero-sub reveal" data-d="2">
    Saya <strong>Isnaeni Hidayat</strong> — <strong>Fullstack Developer</strong> &amp; <strong>AI Engineer</strong>.
    Saya merancang, membangun, dan men-<em>ship</em> aplikasi web modern yang ditenagai AI — dari arsitektur backend sampai antarmuka yang terasa hidup.
  </p>

  <div class="hero-meta">
    <div class="item reveal" data-d="2">
      <div class="k"><span data-count="6" data-suffix="+">6+</span></div>
      <div class="l">Years building</div>
    </div>
    <div class="item reveal" data-d="3">
      <div class="k"><span data-count="40" data-suffix="+">40+</span></div>
      <div class="l">Projects shipped</div>
    </div>
    <div class="item reveal" data-d="4">
      <div class="k"><span data-count="15" data-suffix="+">15+</span></div>
      <div class="l">AI systems</div>
    </div>
  </div>

  <div class="hero-actions reveal" data-d="3">
    <a href="#work" class="btn btn-primary" data-magnetic="0.3" id="hero-cta-work">
      View selected work <span class="arrow" aria-hidden="true">↗</span>
    </a>
    <a href="#contact" class="btn btn-ghost" data-magnetic="0.3" id="hero-cta-contact">
      Get in touch
    </a>
  </div>

  <!-- tech marquee -->
  <div class="marquee reveal" aria-hidden="true">
    <div class="marquee-track">
      <span>TypeScript</span><span>React</span><span>Next.js</span><span>Node.js</span><span>Python</span><span>FastAPI</span><span>PostgreSQL</span><span>LangChain</span><span>PyTorch</span><span>Docker</span><span>AWS</span><span>Vector DB</span>
      <span>TypeScript</span><span>React</span><span>Next.js</span><span>Node.js</span><span>Python</span><span>FastAPI</span><span>PostgreSQL</span><span>LangChain</span><span>PyTorch</span><span>Docker</span><span>AWS</span><span>Vector DB</span>
    </div>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <div class="scroll-bar"></div>
    SCROLL
  </div>

</header>
