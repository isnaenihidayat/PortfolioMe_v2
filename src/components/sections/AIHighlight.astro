---
// AIHighlight.astro
---

<section id="ai" class="section-pad wrap">
  <div class="ai-band reveal">
    <div class="ai-inner">

      <div class="ai-copy">
        <span class="eyebrow">AI Engineering</span>
        <h3>Where models meet <em>real products.</em></h3>
        <p>
          Bukan sekadar memanggil API. Saya membangun sistem AI yang andal di produksi — dengan retrieval yang tepat, evaluasi yang terukur, dan biaya yang terkendali.
        </p>
        <div class="ai-feats">
          <div class="ai-feat">
            <span class="fi" aria-hidden="true">01</span>
            <div class="ft">
              <strong>RAG &amp; retrieval</strong>
              <span>Chunking, embeddings, hybrid search, re-ranking, sitasi.</span>
            </div>
          </div>
          <div class="ai-feat">
            <span class="fi" aria-hidden="true">02</span>
            <div class="ft">
              <strong>Agentic workflows</strong>
              <span>Tool-use, planning, orkestrasi multi-step yang dapat diaudit.</span>
            </div>
          </div>
          <div class="ai-feat">
            <span class="fi" aria-hidden="true">03</span>
            <div class="ft">
              <strong>Eval &amp; guardrails</strong>
              <span>Testing, observability, dan kontrol kualitas output.</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Terminal card — typing animation handled by JS in Sprint 3 -->
      <div class="terminal reveal" data-d="2" aria-label="Terminal showing developer profile">
        <div class="term-bar" aria-hidden="true">
          <span class="d"></span>
          <span class="d"></span>
          <span class="d"></span>
          <span class="t">~/isnaeni — zsh</span>
        </div>
        <div class="term-body" id="terminal-body" role="log" aria-live="polite" aria-label="Terminal output"></div>
      </div>

    </div>
  </div>
</section>
