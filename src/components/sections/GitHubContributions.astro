---
// GitHubContributions.astro — Enhanced with stats cards + SVG heatmap + 2D/3D toggle
const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;
const user = "isnaenihidayat";

interface ContribDay {
  count: number;
  date: string;
}

interface Week {
  days: ContribDay[];
}

let totalContributions = 0;
let weeks: Week[] = [];
let fetchOk = false;
let bestDay = { count: 0, date: "" };
let thisWeekCount = 0;

if (GITHUB_TOKEN) {
  try {
    const res = await fetch("https://api.github.com/graphql", {
      method: "POST",
      headers: {
        Authorization: `Bearer ${GITHUB_TOKEN}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        query: `{
          user(login: "${user}") {
            contributionsCollection {
              contributionCalendar {
                totalContributions
                weeks {
                  contributionDays {
                    contributionCount
                    date
                  }
                }
              }
            }
          }
        }`,
      }),
    });

    const json = await res.json();
    const cal = json?.data?.user?.contributionsCollection?.contributionCalendar;

    if (cal) {
      totalContributions = cal.totalContributions;
      weeks = cal.weeks.map((w: any) => ({
        days: w.contributionDays.map((d: any) => ({
          count: d.contributionCount,
          date: d.date,
        })),
      }));
      fetchOk = true;

      // Best day
      weeks.forEach(w =>
        w.days.forEach(d => {
          if (d.count > bestDay.count) bestDay = d;
        })
      );

      // This week (last week in array)
      const lastWeek = weeks[weeks.length - 1];
      if (lastWeek) {
        thisWeekCount = lastWeek.days.reduce((s, d) => s + d.count, 0);
      }
    }
  } catch (e) {
    console.warn("[GitHubContributions] fetch failed:", e);
  }
}

// ── Generate synthetic data if no token ──────────────────────────────────────
if (!fetchOk) {
  const now = new Date();
  const start = new Date(now);
  start.setFullYear(now.getFullYear() - 1);
  start.setDate(start.getDate() - start.getDay()); // align to Sunday

  for (let w = 0; w < 53; w++) {
    const days: ContribDay[] = [];
    for (let d = 0; d < 7; d++) {
      const date = new Date(start);
      date.setDate(start.getDate() + w * 7 + d);
      if (date > now) break;
      // Synthetic pattern — more active mid-week
      const rand = Math.random();
      const count = rand < 0.3 ? 0 : rand < 0.5 ? 1 : rand < 0.7 ? 3 : rand < 0.85 ? 6 : rand < 0.95 ? 10 : 15;
      days.push({ count, date: date.toISOString().slice(0, 10) });
      totalContributions += count;
      if (count > bestDay.count) bestDay = { count, date: date.toISOString().slice(0, 10) };
    }
    if (days.length) weeks.push({ days });
  }
  const lastWeek = weeks[weeks.length - 1];
  if (lastWeek) thisWeekCount = lastWeek.days.reduce((s, d) => s + d.count, 0);
  fetchOk = true;
}

// ── Month labels ──────────────────────────────────────────────────────────────
const MONTH_NAMES = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
const monthLabels: { name: string; col: number }[] = [];
let lastMonth = -1;
weeks.forEach((week, i) => {
  const d = week.days[0];
  if (d) {
    const m = new Date(d.date).getMonth();
    if (m !== lastMonth) {
      monthLabels.push({ name: MONTH_NAMES[m], col: i });
      lastMonth = m;
    }
  }
});

// ── Contribution level 0–4 ────────────────────────────────────────────────────
function getLevel(count: number): 0 | 1 | 2 | 3 | 4 {
  if (count === 0) return 0;
  if (count <= 3) return 1;
  if (count <= 6) return 2;
  if (count <= 9) return 3;
  return 4;
}

function fmt(n: number) {
  return n.toLocaleString("id-ID");
}

// ── Best day label ────────────────────────────────────────────────────────────
function fmtDate(iso: string) {
  if (!iso) return "";
  const d = new Date(iso);
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

// ── SVG heatmap constants ────────────────────────────────────────────────────
const CELL = 11;
const GAP = 3;
const STEP = CELL + GAP;
const LABEL_LEFT = 28;
const HEADER_TOP = 14;

const totalWeeks = weeks.length || 53;
const svgW = LABEL_LEFT + totalWeeks * STEP;
const svgH = HEADER_TOP + 7 * STEP + 4;

// ── Streak calculation ────────────────────────────────────────────────────────
let currentStreak = 0;
let longestStreak = 0;
let tempStreak = 0;
const allDays: ContribDay[] = [];
weeks.forEach(w => w.days.forEach(d => allDays.push(d)));
allDays.sort((a, b) => a.date.localeCompare(b.date));
// current streak (from end)
for (let i = allDays.length - 1; i >= 0; i--) {
  if (allDays[i].count > 0) currentStreak++;
  else break;
}
// longest streak
allDays.forEach(d => {
  if (d.count > 0) {
    tempStreak++;
    longestStreak = Math.max(longestStreak, tempStreak);
  } else {
    tempStreak = 0;
  }
});
---

<section id="github" class="section-pad wrap gh-section">
  <div class="gh-card reveal">

    <!-- ── Header ── -->
    <div class="gh-card-header">
      <div class="gh-title">
        <svg class="gh-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor" width="20" height="20">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        <span class="gh-label-mono">Contribution Activity</span>
      </div>
      <div class="gh-header-right">
        <!-- 2D/3D toggle -->
        <div class="gh-toggle" id="gh-view-toggle" aria-label="Toggle heatmap view">
          <button class="gh-toggle-btn active" id="gh-btn-2d" aria-pressed="true">2D</button>
          <button class="gh-toggle-btn" id="gh-btn-3d" aria-pressed="false">3D</button>
        </div>
        <a href={`https://github.com/${user}`} target="_blank" rel="noopener noreferrer"
           class="gh-view-link" id="github-view-link" aria-label="View GitHub profile">
          View GitHub →
        </a>
      </div>
    </div>

    <!-- ── Stats cards ── -->
    <div class="gh-stats-grid">

      <div class="gh-stat-card">
        <span class="gh-stat-label">Total Contributions</span>
        <div class="gh-stat-value-row">
          <span class="gh-stat-value" style="color: var(--accent)">{fmt(totalContributions)}</span>
        </div>
        <span class="gh-stat-sub">Last 365 days</span>
      </div>

      <div class="gh-stat-card">
        <span class="gh-stat-label">This Week</span>
        <div class="gh-stat-value-row">
          <span class="gh-stat-value" style="color: var(--accent)">{thisWeekCount}</span>
        </div>
        <span class="gh-stat-sub">Current week</span>
      </div>

      <div class="gh-stat-card">
        <span class="gh-stat-label">Best Day</span>
        <div class="gh-stat-value-row">
          <span class="gh-stat-value" style="color: #ff5722">{bestDay.count}</span>
          <span class="gh-stat-unit">commits</span>
        </div>
        <span class="gh-stat-sub gh-stat-sub--truncate" title={fmtDate(bestDay.date)}>{fmtDate(bestDay.date)}</span>
      </div>

      <div class="gh-stat-card">
        <span class="gh-stat-label">Current Streak</span>
        <div class="gh-stat-value-row">
          <span class="gh-stat-value" style="color: #10b981">{currentStreak}</span>
          <span class="gh-stat-unit">days</span>
        </div>
        <span class="gh-stat-sub">Active streak</span>
      </div>

      <div class="gh-stat-card gh-stat-card--wide">
        <span class="gh-stat-label">Longest Streak</span>
        <div class="gh-stat-value-row">
          <span class="gh-stat-value" style="color: #f59e0b">{longestStreak}</span>
          <span class="gh-stat-unit">days</span>
        </div>
        <span class="gh-stat-sub">All-time record</span>
      </div>

    </div>

    <!-- ── Heatmap container ── -->
    <div class="gh-heatmap-wrap" id="gh-heatmap-wrap">

      <!-- 2D SVG heatmap -->
      <div class="gh-view-2d" id="gh-view-2d">
        <svg
          class="gh-svg"
          width="100%"
          viewBox={`0 0 ${svgW} ${svgH}`}
          shape-rendering="crispEdges"
          preserveAspectRatio="xMidYMid meet"
          aria-label="GitHub contribution calendar"
          role="img"
        >
          <!-- Month labels -->
          {monthLabels.map(({ name, col }) => (
            <text
              x={LABEL_LEFT + col * STEP}
              y={10}
              class="gh-svg-label"
              font-size="9"
              font-family="var(--mono, monospace)"
              fill="currentColor"
            >{name}</text>
          ))}

          <!-- Day labels -->
          {["Mon","Wed","Fri"].map((d, i) => (
            <text
              x={0}
              y={HEADER_TOP + i * 2 * STEP + CELL - 1}
              class="gh-svg-label"
              font-size="9"
              font-family="var(--mono, monospace)"
              fill="currentColor"
            >{d}</text>
          ))}

          <!-- Cells -->
          {weeks.map((week, wi) =>
            Array.from({ length: 7 }).map((_, di) => {
              const day = week.days[di];
              const lvl = day ? getLevel(day.count) : 0;
              const x = LABEL_LEFT + wi * STEP;
              const y = HEADER_TOP + di * STEP;
              const delay = (wi * 7 + di) * 8;
              return (
                <rect
                  x={x}
                  y={y}
                  width={CELL}
                  height={CELL}
                  rx={2}
                  ry={2}
                  class={`gh-cell gh-cell--anim level-${lvl}`}
                  style={`animation-delay:${delay}ms`}
                  title={day ? `${day.date}: ${day.count} contributions` : "No contributions"}
                  role="gridcell"
                  aria-label={day ? `${day.count} contributions on ${day.date}` : "No contributions"}
                />
              );
            })
          )}
        </svg>
      </div>

      <!-- 3D isometric view -->
      <div class="gh-view-3d" id="gh-view-3d" style="display:none" aria-hidden="true">
        <div class="gh-3d-scene" id="gh-3d-scene">
          <div class="gh-3d-grid">
            {weeks.map((week, wi) =>
              Array.from({ length: 7 }).map((_, di) => {
                const day = week.days[di];
                const lvl = day ? getLevel(day.count) : 0;
                const h = [0, 4, 8, 14, 20][lvl];
                const delay = (wi * 7 + di) * 4;
                return (
                  <div
                    class={`gh-bar level-${lvl}`}
                    style={`--bar-h: ${h}px; --wi: ${wi}; --di: ${di}; animation-delay: ${delay}ms;`}
                    title={day ? `${day.date}: ${day.count}` : ""}
                  />
                );
              })
            )}
          </div>
        </div>
      </div>

    </div>

    <!-- ── Footer ── -->
    <div class="gh-footer">
      <a class="gh-learn" href="https://docs.github.com/articles/why-are-my-contributions-not-showing-up-on-my-profile" target="_blank" rel="noopener noreferrer">
        Learn how GitHub counts contributions
      </a>
      <div class="gh-legend" aria-label="Contribution intensity scale">
        <span>Less</span>
        {[0,1,2,3,4].map(l => <div class={`gh-legend-cell level-${l}`} aria-label={`Level ${l}`} />)}
        <span>More</span>
      </div>
    </div>

  </div>
</section>

<script>
  // ── 2D / 3D toggle ───────────────────────────────────────────────────────
  const btn2d = document.getElementById('gh-btn-2d') as HTMLButtonElement | null;
  const btn3d = document.getElementById('gh-btn-3d') as HTMLButtonElement | null;
  const view2d = document.getElementById('gh-view-2d') as HTMLElement | null;
  const view3d = document.getElementById('gh-view-3d') as HTMLElement | null;

  function setView(mode: '2d' | '3d') {
    if (!view2d || !view3d || !btn2d || !btn3d) return;
    const is2d = mode === '2d';
    view2d.style.display = is2d ? '' : 'none';
    view3d.style.display = is2d ? 'none' : '';
    view3d.setAttribute('aria-hidden', String(is2d));
    btn2d.classList.toggle('active', is2d);
    btn3d.classList.toggle('active', !is2d);
    btn2d.setAttribute('aria-pressed', String(is2d));
    btn3d.setAttribute('aria-pressed', String(!is2d));
  }

  btn2d?.addEventListener('click', () => setView('2d'));
  btn3d?.addEventListener('click', () => setView('3d'));
</script>

<style>
/* ============================================================
   GITHUB CONTRIBUTION ACTIVITY CARD
   ============================================================ */

.gh-section { padding-top: 0; }

.gh-card {
  position: relative;
  background: var(--color-brand-surface);
  border: 1px solid var(--color-brand-border);
  border-radius: 20px;
  padding: clamp(16px, 2.5vw, 28px);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* subtle grid overlay */
.gh-card::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(var(--color-brand-border) 1px, transparent 1px),
    linear-gradient(90deg, var(--color-brand-border) 1px, transparent 1px);
  background-size: 40px 40px;
  opacity: 0.15;
  -webkit-mask-image: radial-gradient(ellipse at 80% 20%, #000, transparent 65%);
  mask-image: radial-gradient(ellipse at 80% 20%, #000, transparent 65%);
}

/* ── Header ── */
.gh-card-header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}

.gh-title {
  display: flex;
  align-items: center;
  gap: 8px;
}

.gh-icon { color: var(--fg-mid); flex-shrink: 0; }

.gh-label-mono {
  font-family: var(--mono);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--fg-dim, color-mix(in srgb, var(--fg) 45%, transparent));
}

.gh-header-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* ── 2D/3D Toggle ── */
.gh-toggle {
  display: inline-flex;
  padding: 3px;
  background: var(--color-brand-surface-alt, color-mix(in srgb, var(--color-brand-surface) 60%, var(--color-brand-bg)));
  border: 1px solid color-mix(in srgb, var(--color-brand-border) 60%, transparent);
  border-radius: 999px;
  gap: 2px;
}

.gh-toggle-btn {
  padding: 4px 12px;
  font-size: 10px;
  font-weight: 700;
  font-family: var(--mono);
  border-radius: 999px;
  border: none;
  background: transparent;
  color: var(--fg);
  cursor: pointer;
  transition: background 0.2s, color 0.2s, box-shadow 0.2s;
  line-height: 1.4;
}

.gh-toggle-btn.active {
  background: var(--accent);
  color: #fff;
  box-shadow: 0 1px 4px color-mix(in srgb, var(--accent) 40%, transparent);
}

/* ── View profile link ── */
.gh-view-link {
  position: relative;
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--accent);
  border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  padding: 6px 14px;
  border-radius: 999px;
  white-space: nowrap;
  text-decoration: none;
  transition: background 0.2s, color 0.2s, border-color 0.2s;
}

.gh-view-link:hover {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
}

/* ── Stats grid ── */
.gh-stats-grid {
  position: relative;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}

@media (min-width: 480px) {
  .gh-stats-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (min-width: 760px) {
  .gh-stats-grid { grid-template-columns: repeat(5, 1fr); }
}

.gh-stat-card {
  background: color-mix(in srgb, var(--color-brand-surface-alt, var(--color-brand-surface)) 80%, transparent);
  border: 1px solid color-mix(in srgb, var(--color-brand-border) 80%, transparent);
  border-radius: 14px;
  padding: 10px 12px;
  display: flex;
  flex-direction: column;
  gap: 3px;
  position: relative;
  overflow: hidden;
  transition: border-color 0.2s, background 0.2s;
}

.gh-stat-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(to right, transparent, color-mix(in srgb, var(--accent) 20%, transparent), transparent);
}

.gh-stat-card:hover {
  border-color: color-mix(in srgb, var(--accent) 25%, transparent);
}

.gh-stat-card--wide {
  grid-column: span 2;
}

@media (min-width: 480px) {
  .gh-stat-card--wide { grid-column: span 1; }
}

.gh-stat-label {
  font-size: 9px;
  font-weight: 700;
  font-family: var(--mono);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--fg-mid, color-mix(in srgb, var(--fg) 60%, transparent));
}

.gh-stat-value-row {
  display: flex;
  align-items: baseline;
  gap: 4px;
  margin-top: 2px;
}

.gh-stat-value {
  font-size: 1.25rem;
  font-weight: 900;
  font-family: var(--display);
  line-height: 1;
  letter-spacing: -0.02em;
}

.gh-stat-unit {
  font-size: 9px;
  font-family: var(--mono);
  color: var(--fg-dim, color-mix(in srgb, var(--fg) 40%, transparent));
  margin-left: 2px;
}

.gh-stat-sub {
  font-size: 9px;
  font-family: var(--mono);
  color: var(--fg-dim, color-mix(in srgb, var(--fg) 40%, transparent));
}

.gh-stat-sub--truncate {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ── Heatmap wrap ── */
.gh-heatmap-wrap {
  position: relative;
  overflow: hidden;
}

/* ── 2D SVG view ── */
.gh-view-2d {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: color-mix(in srgb, var(--accent) 30%, transparent) transparent;
}

.gh-svg {
  display: block;
  overflow: visible;
  min-width: 540px;
}

.gh-svg-label {
  fill: color-mix(in srgb, var(--fg) 35%, transparent);
  font-size: 9px;
}

/* ── Cell levels ── */
.gh-cell {
  cursor: pointer;
  transition: opacity 0.15s;
  opacity: 0;
}
.gh-cell:hover { opacity: 0.75 !important; }

.gh-cell--anim {
  animation: cellFadeIn 0.4s ease forwards;
}

@keyframes cellFadeIn {
  from { opacity: 0; transform-origin: center; }
  to   { opacity: 1; }
}

@media (prefers-reduced-motion: reduce) {
  .gh-cell--anim { animation: none; opacity: 1; }
}

.level-0 { fill: color-mix(in srgb, var(--color-brand-border) 40%, transparent); }
.level-1 { fill: color-mix(in srgb, var(--accent) 25%, var(--color-brand-surface)); }
.level-2 { fill: color-mix(in srgb, var(--accent) 50%, var(--color-brand-surface)); }
.level-3 { fill: color-mix(in srgb, var(--accent) 75%, var(--color-brand-surface)); }
.level-4 { fill: var(--accent); }

/* ── 3D isometric view ── */
.gh-view-3d {
  width: 100%;
  height: 260px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gh-3d-scene {
  perspective: 800px;
  perspective-origin: 50% 30%;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gh-3d-grid {
  display: grid;
  grid-template-columns: repeat(53, 10px);
  grid-template-rows: repeat(7, 10px);
  gap: 2px;
  transform: rotateX(55deg) rotateZ(-25deg) scale(0.75);
  transform-style: preserve-3d;
  transform-origin: center;
}

.gh-bar {
  width: 10px;
  height: 10px;
  border-radius: 1px;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.2s;
  animation: barRise 0.5s ease forwards;
  opacity: 0;
}

.gh-bar::before {
  content: '';
  position: absolute;
  inset: 0;
  height: var(--bar-h, 0px);
  bottom: 0;
  top: auto;
  transform: translateZ(0) scaleY(1);
  transform-origin: bottom;
  border-radius: 1px 1px 0 0;
}

/* 3D bar colors based on level */
.gh-bar.level-0 { background: color-mix(in srgb, var(--color-brand-border) 30%, transparent); }
.gh-bar.level-1 { background: color-mix(in srgb, var(--accent) 25%, var(--color-brand-surface)); }
.gh-bar.level-2 { background: color-mix(in srgb, var(--accent) 50%, var(--color-brand-surface)); }
.gh-bar.level-3 { background: color-mix(in srgb, var(--accent) 75%, var(--color-brand-surface)); }
.gh-bar.level-4 { background: var(--accent); }

@keyframes barRise {
  from { opacity: 0; transform: scaleY(0); transform-origin: bottom; }
  to   { opacity: 1; transform: scaleY(1); }
}

@media (prefers-reduced-motion: reduce) {
  .gh-bar { animation: none; opacity: 1; }
}

/* ── Footer ── */
.gh-footer {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 4px;
}

.gh-learn {
  font-family: var(--mono);
  font-size: 0.7rem;
  color: var(--fg-dim, color-mix(in srgb, var(--fg) 40%, transparent));
  text-decoration: none;
