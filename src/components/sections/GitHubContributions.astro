---
// GitHubContributions.astro
// Fetches REAL data from GitHub GraphQL API at build time
const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;
const user = "isnaenihidayat";

interface ContribDay {
  count: number;
  date: string;
}

interface Week {
  days: ContribDay[];
}

let totalContributions = 0;
let weeks: Week[] = [];
let fetchOk = false;

if (GITHUB_TOKEN) {
  try {
    const res = await fetch("https://api.github.com/graphql", {
      method: "POST",
      headers: {
        Authorization: `Bearer ${GITHUB_TOKEN}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        query: `{
          user(login: "${user}") {
            contributionsCollection {
              contributionCalendar {
                totalContributions
                weeks {
                  contributionDays {
                    contributionCount
                    date
                  }
                }
              }
            }
          }
        }`,
      }),
    });

    const json = await res.json();
    const cal =
      json?.data?.user?.contributionsCollection?.contributionCalendar;

    if (cal) {
      totalContributions = cal.totalContributions;
      weeks = cal.weeks.map((w: any) => ({
        days: w.contributionDays.map((d: any) => ({
          count: d.contributionCount,
          date: d.date,
        })),
      }));
      fetchOk = true;
    }
  } catch (e) {
    console.warn("[GitHubContributions] fetch failed:", e);
  }
}

// ── Month labels ─────────────────────────────────────────────────────────────
const MONTH_NAMES = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
const monthLabels: { name: string; col: number }[] = [];
let lastMonth = -1;
weeks.forEach((week, i) => {
  const d = week.days[0];
  if (d) {
    const m = new Date(d.date).getMonth();
    if (m !== lastMonth) {
      monthLabels.push({ name: MONTH_NAMES[m], col: i });
      lastMonth = m;
    }
  }
});

// ── Contribution level 0–4 ────────────────────────────────────────────────────
function getLevel(count: number): 0 | 1 | 2 | 3 | 4 {
  if (count === 0) return 0;
  if (count <= 3) return 1;
  if (count <= 6) return 2;
  if (count <= 9) return 3;
  return 4;
}

// ── Number format: 7280 → "7.280" ─────────────────────────────────────────────
function fmt(n: number) {
  return n.toLocaleString("id-ID");
}

const totalWeeks = weeks.length || 53;
---

<section id="github" class="section-pad wrap" style="padding-top: 5px; padding-bottom: 5px;">
  <div class="gh-card reveal">

    <!-- ── Card header ── -->
    <div class="gh-card-header">
      <div class="gh-title">
        <!-- GitHub logo SVG -->
        <svg class="gh-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor" width="22" height="22">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        <h2>GitHub Contributions</h2>
      </div>
      <a
        href={`https://github.com/${user}`}
        target="_blank"
        rel="noopener noreferrer"
        class="gh-view-link"
        id="github-view-link"
        aria-label="View GitHub profile"
      >
        View GitHub <span aria-hidden="true">→</span>
      </a>
    </div>

    {fetchOk ? (
      <>
        <!-- ── Subtitle ── -->
        <p class="gh-subtitle">
          {fmt(totalContributions)} contributions in the last year
        </p>

        <!-- ── Divider ── -->
        <div class="gh-divider" role="separator" aria-hidden="true"></div>

        <!-- ── Calendar ── -->
        <div class="gh-calendar-wrap">

          <!-- Month labels -->
          <div class="gh-months" style={`grid-template-columns: repeat(${totalWeeks}, 1fr)`}>
            {monthLabels.map(({ name, col }) => (
              <span
                class="gh-month-label"
                style={`grid-column: ${col + 1}`}
                aria-hidden="true"
              >{name}</span>
            ))}
          </div>

          <!-- Grid of weeks × days -->
          <div class="gh-grid" role="group" aria-label="GitHub contribution calendar">
            {weeks.map((week) => (
              <div class="gh-week">
                {Array.from({ length: 7 }).map((_, di) => {
                  const day = week.days[di];
                  const lvl = day ? getLevel(day.count) : 0;
                  const label = day
                    ? `${day.count} contribution${day.count !== 1 ? "s" : ""} on ${day.date}`
                    : "No contributions";
                  return (
                    <div
                      class={`gh-day lv${lvl}`}
                      title={day ? `${day.date}: ${day.count} contributions` : ""}
                      aria-label={label}
                      role="gridcell"
                    />
                  );
                })}
              </div>
            ))}
          </div>

        </div>

        <!-- ── Footer legend ── -->
        <div class="gh-footer">
          <a
            class="gh-learn"
            href="https://docs.github.com/articles/why-are-my-contributions-not-showing-up-on-my-profile"
            target="_blank"
            rel="noopener noreferrer"
          >
            Learn how GitHub counts contributions
          </a>
          <div class="gh-legend" aria-label="Contribution intensity scale">
            <span>Less</span>
            <div class="gh-day lv0" aria-label="No contributions"></div>
            <div class="gh-day lv1" aria-label="Low contributions"></div>
            <div class="gh-day lv2" aria-label="Medium contributions"></div>
            <div class="gh-day lv3" aria-label="High contributions"></div>
            <div class="gh-day lv4" aria-label="Very high contributions"></div>
            <span>More</span>
          </div>
        </div>
      </>
    ) : (
      <!-- Fallback when no token -->
      <div class="gh-fallback">
        <p class="gh-subtitle">Set <code>GITHUB_TOKEN</code> environment variable to display live data.</p>
        <p class="gh-learn">
          <a href={`https://github.com/${user}`} target="_blank" rel="noopener noreferrer">
            View full profile on GitHub ↗
          </a>
        </p>
      </div>
    )}

  </div>
</section>

<style>
/* ── Card shell — mirrors ai-band style ── */
.gh-card {
  position: relative;
  border: 1px solid var(--color-brand-border);
  border-radius: 24px;
  overflow: hidden;
  background: linear-gradient(160deg, var(--color-brand-surface), var(--color-brand-bg));
  padding: clamp(24px, 3.5vw, 40px) clamp(20px, 4vw, 48px) clamp(20px, 3vw, 32px);
}
/* subtle dot-grid overlay — same pattern as ai-band::before */
.gh-card::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(var(--color-brand-border) 1px, transparent 1px),
    linear-gradient(90deg, var(--color-brand-border) 1px, transparent 1px);
  background-size: 40px 40px;
  opacity: 0.3;
  -webkit-mask-image: radial-gradient(circle at 10% 80%, #000, transparent 65%);
  mask-image: radial-gradient(circle at 10% 80%, #000, transparent 65%);
}

/* ── Header ── */
.gh-card-header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.gh-title {
  display: flex;
  align-items: center;
  gap: 10px;
}
.gh-icon { color: var(--fg-mid); flex-shrink: 0; }
.gh-title h2 {
  font-family: var(--display);
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  font-weight: 600;
  color: var(--fg);
  margin: 0;
  letter-spacing: -0.02em;
}
.gh-view-link {
  position: relative;
  font-family: var(--mono);
  font-size: 0.8rem;
  color: var(--accent);
  border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  padding: 7px 16px;
  border-radius: 999px;
  white-space: nowrap;
  transition: background 0.25s var(--ease), color 0.25s, border-color 0.25s;
}
.gh-view-link:hover {
  background: var(--accent);
  color: var(--color-brand-bg);
  border-color: var(--accent);
}

/* ── Subtitle ── */
.gh-subtitle {
  position: relative;
  margin: 10px 0 0;
  font-family: var(--mono);
  font-size: 0.8rem;
  color: var(--fg-dim);
  letter-spacing: 0.04em;
}

/* ── Divider ── */
.gh-divider {
  position: relative;
  border: none;
  border-top: 1px dashed var(--color-brand-border);
  margin: 20px 0 18px;
}

/* ── Calendar wrapper ── */
.gh-calendar-wrap {
  position: relative;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: var(--line) transparent;
}

/* ── Month labels ── */
.gh-months {
  display: grid;
  margin-bottom: 4px;
  min-width: max-content;
}
.gh-month-label {
  font-family: var(--mono);
  font-size: 0.7rem;
  color: var(--fg-faint);
  line-height: 1;
  letter-spacing: 0.04em;
}

/* ── Week × Day grid ── */
.gh-grid {
  display: flex;
  gap: 3px;
  min-width: max-content;
}
.gh-week {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.gh-day {
  width: 11px;
  height: 11px;
  border-radius: 2px;
  flex-shrink: 0;
  transition: opacity 0.15s;
}
.gh-day:hover { opacity: 0.75; }

/* Contribution levels — portfolio-tinted purples (matching biru-violet palette) */
.lv0 { background: var(--color-brand-surface-alt); opacity: 0.6; }
.lv1 { background: color-mix(in srgb, var(--accent-3) 30%, var(--color-brand-surface-alt)); opacity: 1; }
.lv2 { background: color-mix(in srgb, var(--accent-3) 55%, var(--color-brand-surface-alt)); opacity: 1; }
.lv3 { background: var(--accent-3); opacity: 1; }
.lv4 { background: var(--accent); opacity: 1; }

/* ── Footer ── */
.gh-footer {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 16px;
}
.gh-learn {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--fg-faint);
  text-decoration: none;
  transition: color 0.2s;
}
.gh-learn:hover { color: var(--accent); }
.gh-legend {
  display: flex;
  align-items: center;
  gap: 4px;
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--fg-faint);
  letter-spacing: 0.04em;
}
.gh-legend .gh-day { cursor: default; }
.gh-legend span { padding: 0 3px; }

/* ── Fallback ── */
.gh-fallback { position: relative; padding: 24px 0 8px; }
.gh-fallback code {
  background: var(--color-brand-surface-alt);
  padding: 2px 6px;
  border-radius: 4px;
  font-family: var(--mono);
  font-size: 0.85em;
  color: var(--accent-2);
  border: 1px solid var(--color-brand-border);
}
.gh-fallback a { color: var(--accent); }

/* ── Responsive ── */
@media (max-width: 600px) {
  .gh-card { border-radius: 16px; }
  .gh-day { width: 10px; height: 10px; }
  .gh-grid { gap: 2px; }
  .gh-week { gap: 2px; }
}
</style>

