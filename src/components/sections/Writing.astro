---
// Writing.astro
import PostCard from '../PostCard.astro';

const posts = [
  {
    tag: 'AI ENGINEERING',
    readTime: '8 min',
    title: 'Membangun RAG yang benar-benar bisa dipercaya',
    excerpt: 'Pelajaran dari membawa retrieval-augmented generation dari demo ke produksi tanpa halusinasi.',
    href: '#',
    delay: undefined,
  },
  {
    tag: 'ARCHITECTURE',
    readTime: '6 min',
    title: 'Satu codebase, dua otak: web + AI',
    excerpt: 'Pola arsitektur untuk menggabungkan layanan ML dengan aplikasi fullstack tanpa kekacauan.',
    href: '#',
    delay: '2',
  },
  {
    tag: 'CRAFT',
    readTime: '5 min',
    title: 'Animasi yang terasa, bukan yang berlebihan',
    excerpt: 'Bagaimana motion yang tepat membuat antarmuka terasa hidup tanpa mengganggu.',
    href: '#',
    delay: '3',
  },
];
---

<section id="writing" class="section-pad wrap">
  <div class="section-head reveal">
    <div>
      <span class="eyebrow">Writing</span>
      <h2 class="section-title" style="margin-top:18px">Notes &amp; ideas</h2>
    </div>
    <span class="section-index" aria-hidden="true">/ 06 — 06</span>
  </div>

  <div class="blog-grid">
    {posts.map(post => (
      <PostCard {...post} />
    ))}
  </div>
</section>
