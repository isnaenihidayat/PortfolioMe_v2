---
// Writing.astro — Writing cards with hero image, badges, and arrow animation

interface Post {
  tag: string;
  lang: 'ID' | 'EN';
  readTime: string;
  title: string;
  excerpt: string;
  href: string;
  image?: string;
}

const posts: Post[] = [
  {
    tag: 'AI Engineering',
    lang: 'ID',
    readTime: '8 min',
    title: 'Membangun RAG yang benar-benar bisa dipercaya',
    excerpt: 'Pelajaran dari membawa retrieval-augmented generation dari demo ke produksi tanpa halusinasi — dan apa yang sering salah.',
    href: '#',
  },
  {
    tag: 'Architecture',
    lang: 'ID',
    readTime: '6 min',
    title: 'Satu codebase, dua otak: web + AI',
    excerpt: 'Pola arsitektur untuk menggabungkan layanan ML dengan aplikasi fullstack tanpa kekacauan yang biasanya terjadi.',
    href: '#',
  },
  {
    tag: 'Craft',
    lang: 'EN',
    readTime: '5 min',
    title: 'Animation that feels, not overwhelms',
    excerpt: 'How the right motion design makes interfaces feel alive without becoming a distraction to the user.',
    href: '#',
  },
];
---

<section id="writing" class="section-pad wrap">
  <div class="section-head reveal">
    <div>
      <span class="eyebrow">Writing</span>
      <h2 class="section-title" style="margin-top:18px">Notes &amp; ideas</h2>
    </div>
    <span class="section-index" aria-hidden="true">/ 07 — 07</span>
  </div>

  <div class="writing-grid">
    {posts.map((post, i) => (
      <a href={post.href} class="writing-card reveal" data-d={String(i)} aria-label={post.title}>
        <!-- Glow -->
        <div class="writing-card-glow"></div>

        <!-- Hero image area -->
        <div class="writing-hero">
          <div class="writing-hero-placeholder">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.3">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <!-- Language badge -->
          <div class="writing-hero-overlay">
            <span class={`lang-badge-hero ${post.lang === 'ID' ? 'lang-id-hero' : 'lang-en-hero'}`}>
              {post.lang}
            </span>
          </div>
        </div>

        <!-- Card body -->
        <div class="writing-card-body">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
            <span class="writing-tag">{post.tag}</span>
            <span class="writing-date">{post.readTime} read</span>
          </div>

          <h3 class="writing-title">{post.title}</h3>
          <p class="writing-desc">{post.excerpt}</p>

          <div style="margin-top:auto;padding-top:14px;border-top:1px solid var(--color-brand-border)">
            <div class="writing-arrow-wrapper">
              Read more
              <span class="writing-arrow">→</span>
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .writing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
  }
  @media (max-width: 1024px) { .writing-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .writing-grid { grid-template-columns: 1fr; } }

  .writing-card {
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: rgba(17, 21, 32, 0.4);
    border: 1px solid var(--color-brand-border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    color: inherit;
  }
  [data-theme="light"] .writing-card { background: rgba(255,255,255,0.6); }
  .writing-card:hover {
    border-color: color-mix(in srgb, var(--color-brand-accent) 40%, var(--color-brand-border));
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.3), 0 0 1px color-mix(in srgb, var(--color-brand-accent) 20%, transparent);
  }

  .writing-card-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(280px circle at 50% 30%, color-mix(in srgb, var(--color-brand-accent) 10%, transparent), transparent 100%);
    transition: opacity 0.5s ease;
    z-index: 1;
  }
  .writing-card:hover .writing-card-glow { opacity: 1; }

  .writing-hero {
    position: relative;
    width: 100%;
    height: 160px;
    overflow: hidden;
    background: var(--color-brand-surface);
    border-bottom: 1px solid var(--color-brand-border);
  }
  .writing-hero-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--color-brand-surface-alt), var(--color-brand-surface));
    color: var(--color-brand-text-tertiary);
  }
  .writing-hero-overlay {
    position: absolute;
    top: 10px; right: 10px;
    z-index: 3;
  }
  .lang-badge-hero {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,0.15);
    backdrop-filter: blur(6px);
  }
  .lang-id-hero { background: rgba(57,211,83,0.15); color: #2ea043; border-color: rgba(57,211,83,0.25); }
  .lang-en-hero { background: rgba(59,130,246,0.15); color: #3b82f6; border-color: rgba(59,130,246,0.25); }

  .writing-card-body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 18px 20px;
  }
  .writing-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-brand-accent);
    background: color-mix(in srgb, var(--color-brand-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-brand-accent) 15%, transparent);
    border-radius: 4px;
    padding: 2px 8px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: border-color 0.3s ease, color 0.3s ease;
  }
  .writing-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-brand-text-tertiary);
    white-space: nowrap;
    transition: color 0.3s ease;
    margin-left: auto;
  }
  .writing-card:hover .writing-date { color: var(--color-brand-accent); }
  .writing-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-brand-text-primary);
    line-height: 1.4;
    margin: 0 0 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .writing-desc {
    font-size: 0.82rem;
    color: var(--color-brand-text-secondary);
    line-height: 1.6;
    margin: 0 0 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .writing-arrow-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-brand-text-tertiary);
    transition: color 0.3s ease;
  }
  .writing-arrow {
    transform: translate(-1px, 1px);
    transition: transform 0.3s ease, color 0.3s ease;
    display: inline-block;
  }
  .writing-card:hover .writing-arrow-wrapper { color: var(--color-brand-accent-hover); }
  .writing-card:hover .writing-arrow { transform: translate(0, 0); color: var(--color-brand-accent-hover); }

  @media (prefers-reduced-motion: reduce) {
    .writing-card, .writing-card:hover { box-shadow: none !important; }
    .writing-card, .writing-card:hover { transition: none !important; transform: none !important; }
    .writing-card-glow { display: none !important; }
  }
</style>
