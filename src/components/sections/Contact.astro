---
// Contact.astro — Radar card + animated pointer + float tags, faithful to faisalaffan.com
---

<section id="contact" class="section-pad wrap">
  <div class="section-head reveal">
    <div>
      <span class="eyebrow">Contact</span>
      <h2 class="section-title" style="margin-top:18px">Let's work together</h2>
    </div>
    <span class="section-index" aria-hidden="true">/ 07 — 07</span>
  </div>

  <div class="contact-card reveal" data-d="2" id="contact-card">
    <!-- Border gradient -->
    <div class="contact-card-border" aria-hidden="true"></div>

    <!-- Mouse glow -->
    <div class="contact-glow" id="contact-glow" aria-hidden="true"></div>

    <div class="contact-card-inner">
      <!-- LEFT: CTA copy -->
      <div class="contact-copy">
        <h3 class="contact-heading">
          Punya ide projek,<br />atau butuh bantuan IT?
        </h3>
        <p class="contact-subtext">
          Pintu saya selalu terbuka. Mari ngobrol — dari quick consultation
          sampai full system build, saya siap bantu wujudkan.
        </p>

        <a
          href="mailto:isnaeni.hidayat@outlook.com"
          class="contact-cta"
          id="contact-email-cta"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Kirim Email
          <span>↗</span>
        </a>

        <div class="contact-social-links">
          <a
            class="contact-social-link"
            href="https://wa.me/6287804528887"
            target="_blank"
            rel="noopener noreferrer"
            id="social-whatsapp"
            aria-label="Chat via WhatsApp"
            title="WhatsApp"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <a
            class="contact-social-link"
            href="https://github.com/isnaenihidayat"
            target="_blank"
            rel="noopener noreferrer"
            id="social-github"
            aria-label="GitHub Profile"
            title="GitHub"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a
            class="contact-social-link"
            href="https://www.linkedin.com/in/isnaeni-hidayat/"
            target="_blank"
            rel="noopener noreferrer"
            id="social-linkedin"
            aria-label="LinkedIn Profile"
            title="LinkedIn"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- RIGHT: Radar visual -->
      <div class="contact-visual" id="contact-visual" aria-hidden="true">
        <!-- Animated simulated pointer -->
        <div class="simulated-pointer" id="sim-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
            <path d="M4.5 3.88l4.432 14.636a.75.75 0 0 0 1.382.162l2.985-5.97 5.97-2.985a.75.75 0 0 0-.162-1.382L4.5 3.88z"/>
            <path d="M12.348 15.348 17 20" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>

        <!-- Float tags around radar -->
        <div class="contact-float-tag" data-tag="email" style="top:12%;left:8%">✉ Email</div>
        <div class="contact-float-tag" data-tag="whatsapp" style="top:15%;right:6%">✆ WA</div>
        <div class="contact-float-tag" data-tag="github" style="bottom:20%;left:5%">⌥ GitHub</div>
        <div class="contact-float-tag" data-tag="linkedin" style="bottom:18%;right:4%">in LinkedIn</div>

        <!-- Radar rings -->
        <div class="contact-visual-radar radar-outer"></div>
        <div class="contact-visual-radar radar-mid"></div>
        <div class="contact-visual-radar radar-inner"></div>

        <!-- Center icon -->
        <div class="contact-visual-center" id="contact-center">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Mouse glow
  const card = document.getElementById('contact-card');
  const glow = document.getElementById('contact-glow');

  card?.addEventListener('mouseenter', () => { if (glow) glow.style.opacity = '1'; });
  card?.addEventListener('mouseleave', () => { if (glow) glow.style.opacity = '0'; });
  card?.addEventListener('mousemove', (e) => {
    const rect = card.getBoundingClientRect();
    const x = ((e as MouseEvent).clientX - rect.left) / rect.width * 100;
    const y = ((e as MouseEvent).clientY - rect.top) / rect.height * 100;
    card.style.setProperty('--mouse-x', `${x}%`);
    card.style.setProperty('--mouse-y', `${y}%`);
  });

  // Simulated pointer animation cycling through float tags
  const visual = document.getElementById('contact-visual');
  const pointer = document.getElementById('sim-pointer');
  const center = document.getElementById('contact-center');
  const floatTags = document.querySelectorAll<HTMLElement>('.contact-float-tag');

  let currentTag = 0;
  function animatePointer() {
    if (!visual || !pointer) return;
    const vRect = visual.getBoundingClientRect();
    const tag = floatTags[currentTag];
    if (!tag) return;

    // Reset active states
    floatTags.forEach(t => t.classList.remove('active'));
    center?.classList.remove('active');

    // Animate pointer to tag
    const tagRect = tag.getBoundingClientRect();
    const tx = tagRect.left - vRect.left + tagRect.width / 2;
    const ty = tagRect.top - vRect.top + tagRect.height / 2;

    pointer.style.transform = `translate(${tx}px, ${ty}px)`;
    tag.classList.add('active');
    center?.classList.add('active');

    currentTag = (currentTag + 1) % floatTags.length;
  }

  // Start animation when section in view
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        animatePointer();
        setInterval(animatePointer, 2200);
        obs.disconnect();
      }
    });
  }, { threshold: 0.3 });
  if (visual) obs.observe(visual);
</script>

<style>
  .contact-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    transition: box-shadow 0.4s ease;
  }
  .contact-card-border {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    padding: 1px;
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-brand-accent) 30%, transparent), transparent 50%, color-mix(in srgb, var(--color-brand-accent) 15%, transparent));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 5;
  }
  .contact-glow {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(350px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      color-mix(in srgb, var(--color-brand-accent) 12%, transparent),
      transparent 100%);
    transition: opacity 0.5s ease;
  }
  .contact-card-inner {
    position: relative;
    z-index: 20;
    border-radius: 23px;
    border: 1px solid var(--color-brand-border);
    background: linear-gradient(135deg, var(--color-brand-bg), color-mix(in srgb, var(--color-brand-surface) 80%, var(--color-brand-bg)));
    padding: 40px 36px;
    display: flex;
    align-items: center;
    gap: 48px;
  }
  @media (max-width: 767px) {
    .contact-card-inner { padding: 28px 20px; gap: 0; flex-direction: column; }
    .contact-visual { display: none; }
  }

  /* Left copy */
  .contact-copy { flex: 1; }
  .contact-heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 6.8vw, 2.25rem);
    line-height: 1.15;
    font-weight: 700;
    color: var(--color-brand-text-primary);
    letter-spacing: -0.025em;
    margin: 0 0 16px;
  }
  @media (min-width: 768px) { .contact-heading { font-size: 2.5rem; } }

  .contact-subtext {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-brand-text-secondary);
    margin: 0 0 24px;
    max-width: 440px;
  }
  .contact-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-brand-accent);
    color: #fff;
    border: none;
    border-radius: 999px;
    padding: 11px 24px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    margin-bottom: 24px;
  }
  .contact-cta:hover {
    background: var(--color-brand-accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--color-brand-accent) 40%, transparent);
  }
  .contact-social-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .contact-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-brand-border);
    color: var(--color-brand-text-tertiary);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, background 0.2s;
  }
  .contact-social-link:hover {
    color: var(--color-brand-accent);
    border-color: var(--color-brand-accent);
    background: color-mix(in srgb, var(--color-brand-accent) 8%, transparent);
    transform: translateY(-2px);
  }

  /* Radar visual */
  .contact-visual {
    position: relative;
    width: 240px;
    height: 240px;
    flex-shrink: 0;
  }
  .contact-visual-radar {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1px dashed color-mix(in srgb, var(--color-brand-accent) 20%, transparent);
    background: transparent;
    pointer-events: none;
    animation: radar-pulse 4s ease-in-out infinite;
  }
  .radar-outer { width: 200px; height: 200px; animation-delay: 0s; }
  .radar-mid { width: 140px; height: 140px; animation-delay: -1.3s; }
  .radar-inner { width: 80px; height: 80px; animation-delay: -2.6s; }
  @keyframes radar-pulse {
    0%, 100% { opacity: 0.3; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.6; transform: translate(-50%, -50%) scale(1.03); }
  }
  .contact-visual-center {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    width: 48px; height: 48px;
    border-radius: 50%;
    background: var(--color-brand-surface);
    border: 1px solid var(--color-brand-border);
    display: flex; align-items: center; justify-content: center;
    z-index: 2;
    color: var(--color-brand-text-secondary);
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .contact-visual-center.active {
    border-color: var(--color-brand-accent);
    background: color-mix(in srgb, var(--color-brand-accent) 8%, var(--color-brand-surface));
    box-shadow: 0 0 16px color-mix(in srgb, var(--color-brand-accent) 25%, transparent);
    color: var(--color-brand-accent);
    transform: translate(-50%, -50%) scale(1.1);
  }
  .contact-float-tag {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid var(--color-brand-border);
    background: var(--color-brand-surface);
    color: var(--color-brand-text-secondary);
    opacity: 0.85;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform, opacity;
    white-space: nowrap;
  }
  .contact-float-tag.active {
    border-color: var(--color-brand-accent);
    color: var(--color-brand-accent);
    background: color-mix(in srgb, var(--color-brand-accent) 10%, var(--color-brand-surface));
    opacity: 1;
    transform: scale(1.08);
  }
  .simulated-pointer {
    position: absolute;
    top: 0; left: 0;
    width: 18px; height: 18px;
    z-index: 30;
    pointer-events: none;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
    will-change: transform;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .contact-visual-radar { animation: none; }
    .simulated-pointer { display: none; }
  }
</style>
