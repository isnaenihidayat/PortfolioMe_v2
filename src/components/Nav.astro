---
// Nav.astro — Fixed navbar with scroll state, active section, and mobile menu
---

<nav class="nav" id="main-nav" aria-label="Main navigation">
  <a href="#top" class="brand" aria-label="Isnaeni Hidayat — Home">
    <span class="mark" aria-hidden="true">IH</span>
    Isnaeni Hidayat
  </a>

  <div class="nav-links" role="list">
    <a href="#about" role="listitem"><span class="n" aria-hidden="true">01</span>About</a>
    <a href="#skills" role="listitem"><span class="n" aria-hidden="true">02</span>Stack</a>
    <a href="#github" role="listitem"><span class="n" aria-hidden="true">03</span>GitHub</a>
    <a href="#work" role="listitem"><span class="n" aria-hidden="true">04</span>Work</a>
    <a href="#ai" role="listitem"><span class="n" aria-hidden="true">05</span>AI</a>
    <a href="#experience" role="listitem"><span class="n" aria-hidden="true">06</span>Journey</a>
    <a href="#writing" role="listitem"><span class="n" aria-hidden="true">07</span>Writing</a>
  </div>

  <a href="#contact" class="nav-cta" data-magnetic="0.4">Let's talk →</a>

  <!-- Mobile hamburger -->
  <button
    class="nav-hamburger"
    id="nav-hamburger"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>
</nav>

<!-- Mobile menu drawer -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
  <div class="mobile-menu-inner">
    <nav class="mobile-links" role="list">
      <a href="#about" role="listitem"><span class="n" aria-hidden="true">01</span>About</a>
      <a href="#skills" role="listitem"><span class="n" aria-hidden="true">02</span>Stack</a>
      <a href="#github" role="listitem"><span class="n" aria-hidden="true">03</span>GitHub</a>
      <a href="#work" role="listitem"><span class="n" aria-hidden="true">04</span>Work</a>
      <a href="#ai" role="listitem"><span class="n" aria-hidden="true">05</span>AI</a>
      <a href="#experience" role="listitem"><span class="n" aria-hidden="true">06</span>Journey</a>
      <a href="#writing" role="listitem"><span class="n" aria-hidden="true">07</span>Writing</a>
    </nav>
    <a href="#contact" class="mobile-cta">Let's talk →</a>
  </div>
</div>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu?.classList.add('open');
    hamburger?.classList.add('active');
    hamburger?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('open');
    hamburger?.classList.remove('active');
    hamburger?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', () => {
    menu?.classList.contains('open') ? closeMenu() : openMenu();
  });

  // Close on any mobile link click
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

  // Close on backdrop click
  menu?.addEventListener('click', (e) => { if (e.target === menu) closeMenu(); });

  // Close on ESC
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
</script>

<style>
  /* ── Hamburger button ── */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 200;
  }
  .nav-hamburger .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--fg);
    border-radius: 2px;
    transition: transform 0.3s var(--ease), opacity 0.3s;
  }
  .nav-hamburger.active .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.active .bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav-hamburger.active .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 860px) { .nav-hamburger { display: flex; } }

  /* ── Mobile menu drawer ── */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 150;
    background: oklch(0.16 0.012 265 / 0.6);
    backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 0.35s var(--ease);
    pointer-events: none;
  }
  .mobile-menu.open { opacity: 1; pointer-events: all; }

  .mobile-menu-inner {
    position: absolute;
    top: 0; right: 0;
    width: min(320px, 85vw);
    height: 100%;
    background: var(--bg-2);
    border-left: 1px solid var(--line-soft);
    display: flex;
    flex-direction: column;
    padding: 100px 36px 60px;
    transform: translateX(100%);
    transition: transform 0.4s var(--ease);
  }
  .mobile-menu.open .mobile-menu-inner { transform: translateX(0); }

  .mobile-links {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .mobile-links a {
    font-family: var(--display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--fg-mid);
    padding: 14px 0;
    letter-spacing: -0.02em;
    border-bottom: 1px solid var(--line-soft);
    display: flex;
    align-items: center;
    gap: 12px;
    transition: color 0.2s, padding-left 0.3s var(--ease);
  }
  .mobile-links a .n {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--accent);
    opacity: 0.8;
  }
  .mobile-links a:hover { color: var(--fg); padding-left: 6px; }

  .mobile-cta {
    margin-top: 36px;
    font-family: var(--mono);
    font-size: 0.88rem;
    padding: 13px 24px;
    border-radius: 999px;
    border: 1px solid var(--accent);
    color: var(--accent);
    text-align: center;
    transition: background 0.25s, color 0.25s;
  }
  .mobile-cta:hover { background: var(--accent); color: var(--bg); }

  @media (max-width: 860px) { .mobile-menu { display: block; } }
</style>
