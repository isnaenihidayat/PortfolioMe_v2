---
// WorkCard.astro
interface Props {
  num: string;
  year: string;
  tag: string;
  title: string;
  desc: string;
  stack: string[];
  href?: string;
  image: string;
  imageAlt: string;
  delay?: string;
}

const { num, year, tag, title, desc, stack, href = '#contact', image, imageAlt, delay } = Astro.props;
---

<article class="work-card reveal" data-d={delay}>
  <div class="work-thumb">
    <span class="work-tag" aria-hidden="true">{tag}</span>
    <img
      src={image}
      alt={imageAlt}
      loading="lazy"
      decoding="async"
      width="800"
      height="500"
    />
  </div>
  <div class="work-top">
    <span class="work-num" aria-hidden="true">{num}</span>
    <span class="work-year">{year}</span>
  </div>
  <div class="work-title">
    {title}
    <a class="work-arrow" href={href} aria-label={`View ${title}`} data-magnetic="0.25">↗</a>
  </div>
  <p class="work-desc">{desc}</p>
  <div class="work-stack" role="list" aria-label={`${title} tech stack`}>
    {stack.map(tech => <span role="listitem">{tech}</span>)}
  </div>
</article>
